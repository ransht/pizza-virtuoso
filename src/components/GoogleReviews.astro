---
import type { Language, Messages } from '../lib/i18n';

interface Props {
  lang: Language;
  t: Messages['reviews'];
  businessUrl: string;
}

const { lang, t, businessUrl } = Astro.props;
---

<div class="google-reviews" data-google-reviews data-endpoint={`/api/reviews?lang=${lang}`} data-copy={JSON.stringify(t)}>
  <div class="reviews-intro">
    <p class="section-kicker">{t.kicker}</p>
    <h2>{t.title}</h2>
    <p>{t.body}</p>
  </div>
  <p class="reviews-status" data-reviews-status role="status">{t.loading}</p>
  <div class="reviews-content" data-reviews-content hidden>
    <header class="reviews-summary">
      <div><strong data-rating></strong><span class="review-stars" aria-hidden="true">★★★★★</span></div>
      <p data-rating-count></p>
      <a data-place-link href={businessUrl} target="_blank" rel="noopener noreferrer">{t.allReviews}</a>
    </header>
    <ol class="review-list" data-review-list></ol>
    <footer class="reviews-attribution">
      <span class="google-maps-attribution" translate="no">Google Maps</span>
      <span>{t.orderNotice}</span>
    </footer>
  </div>
  <div class="reviews-fallback" data-reviews-fallback hidden>
    <p>{t.unavailable}</p>
    <a class="text-link" href={businessUrl} target="_blank" rel="noopener noreferrer">{t.cta} <span aria-hidden="true">↗</span></a>
  </div>
  <noscript><a class="text-link" href={businessUrl} target="_blank" rel="noopener noreferrer">{t.allReviews}</a></noscript>
</div>

<script>
  type ReviewCopy = { basedOn: string; reviewBy: string; viewReview: string; translated: string };
  type GoogleReview = {
    rating?: number;
    relativePublishTimeDescription?: string;
    text?: { text?: string; languageCode?: string };
    originalText?: { text?: string; languageCode?: string };
    googleMapsUri?: string;
    authorAttribution?: { displayName?: string; uri?: string; photoUri?: string };
  };
  type ReviewsResponse = { rating?: number; userRatingCount?: number; googleMapsUri?: string; reviews?: GoogleReview[] };
  const make = <K extends keyof HTMLElementTagNameMap>(tag: K, className?: string) => {
    const element = document.createElement(tag);
    if (className) element.className = className;
    return element;
  };

  document.querySelectorAll<HTMLElement>('[data-google-reviews]').forEach(async (root) => {
    const status = root.querySelector<HTMLElement>('[data-reviews-status]');
    const content = root.querySelector<HTMLElement>('[data-reviews-content]');
    const fallback = root.querySelector<HTMLElement>('[data-reviews-fallback]');
    const list = root.querySelector<HTMLOListElement>('[data-review-list]');
    const rating = root.querySelector<HTMLElement>('[data-rating]');
    const ratingCount = root.querySelector<HTMLElement>('[data-rating-count]');
    const placeLink = root.querySelector<HTMLAnchorElement>('[data-place-link]');
    const copy = JSON.parse(root.dataset.copy || '{}') as ReviewCopy;
    try {
      const response = await fetch(root.dataset.endpoint || '/api/reviews', { headers: { Accept: 'application/json' } });
      if (!response.ok) throw new Error('Reviews are not configured');
      const data = await response.json() as ReviewsResponse;
      if (!data.reviews?.length || typeof data.rating !== 'number') throw new Error('No reviews returned');
      if (rating) rating.textContent = data.rating.toFixed(1);
      if (ratingCount) ratingCount.textContent = copy.basedOn.replace('{count}', String(data.userRatingCount || 0));
      if (placeLink && data.googleMapsUri) placeLink.href = data.googleMapsUri;
      data.reviews.forEach((review) => {
        const item = make('li', 'review-card');
        const authorRow = make('div', 'review-author');
        const author = review.authorAttribution;
        const authorLink = make('a');
        authorLink.href = author?.uri || review.googleMapsUri || '#';
        authorLink.target = '_blank';
        authorLink.rel = 'noopener noreferrer';
        authorLink.setAttribute('aria-label', copy.reviewBy.replace('{name}', author?.displayName || 'Google Maps'));
        if (author?.photoUri) {
          const avatar = make('img');
          avatar.src = author.photoUri; avatar.alt = ''; avatar.width = 44; avatar.height = 44; avatar.loading = 'lazy';
          authorLink.append(avatar);
        } else {
          const avatar = make('span', 'review-avatar-placeholder');
          avatar.textContent = (author?.displayName || 'G').slice(0, 1); avatar.setAttribute('aria-hidden', 'true');
          authorLink.append(avatar);
        }
        const authorCopy = make('div');
        const authorName = make('strong'); authorName.textContent = author?.displayName || 'Google Maps';
        const date = make('span'); date.textContent = review.relativePublishTimeDescription || '';
        authorCopy.append(authorName, date); authorRow.append(authorLink, authorCopy);
        const score = make('div', 'review-score');
        const numeric = Math.max(0, Math.min(5, Math.round(review.rating || 0)));
        score.textContent = `${'★'.repeat(numeric)}${'☆'.repeat(5 - numeric)}`;
        score.setAttribute('aria-label', `${review.rating || 0} / 5`);
        const quote = make('p', 'review-text'); quote.textContent = review.text?.text || '';
        const source = make('a', 'review-source');
        source.href = review.googleMapsUri || data.googleMapsUri || '#'; source.target = '_blank'; source.rel = 'noopener noreferrer'; source.textContent = copy.viewReview;
        item.append(authorRow, score, quote);
        if (review.originalText?.languageCode && review.text?.languageCode && review.originalText.languageCode !== review.text.languageCode) {
          const translated = make('small'); translated.textContent = copy.translated; item.append(translated);
        }
        item.append(source); list?.append(item);
      });
      if (status) status.hidden = true;
      if (content) content.hidden = false;
    } catch {
      if (status) status.hidden = true;
      if (fallback) fallback.hidden = false;
    }
  });
</script>
