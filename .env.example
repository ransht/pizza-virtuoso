# Required on Cloudflare Pages for live Google reviews.
# Enable Places API (New), restrict the key to that API, and set a usage quota.
GOOGLE_PLACES_API_KEY=

# Optional but recommended. Without it, the endpoint uses exact-name Text Search.
GOOGLE_PLACE_ID=

PUBLIC_SITE_URL=https://your-domain.example

# Google Analytics 4 Measurement ID from Admin > Data streams > Web.
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
